{
  "name": "cicd-pipeline-app",
  "version": "1.0.0",
  "description": "CI/CD Pipeline Demo - A production-grade Node.js app with automated deployment",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node node_modules/nodemon/bin/nodemon.js src/server.js",
    "test": "node_modules/.bin/jest --coverage",
    "test:unit": "node_modules/.bin/jest tests/unit",
    "test:integration": "node_modules/.bin/jest tests/integration",
    "lint": "node node_modules/eslint/bin/eslint.js src/ tests/",
    "lint:fix": "node node_modules/eslint/bin/eslint.js src/ tests/ --fix",
    "health": "curl -s http://localhost:3000/health | jq ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
