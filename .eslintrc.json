{
    "env": {
        "node": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_",
                "varsIgnorePattern": "^_"
            }
        ],
        "no-console": "off",
        "semi": [
            "error",
            "always"
        ],
        "quotes": [
            "error",
            "single"
        ],
        "eqeqeq": "error",
        "no-var": "error",
        "prefer-const": "error"
    },
    "overrides": [
        {
            "files": [
                "tests/**/*.js",
                "**/*.test.js",
                "**/*.spec.js"
            ],
            "env": {
                "jest": true
            }
        }
    ]
}